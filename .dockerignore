error2.log
error_log.txt
error_log2.txt

# 緩存與數據 (生產環境或測試環境中，大數據檔案應被排除)
cache
data/raw
data/processed
data/cache

# 備份與歷史歸檔 (只保留 web_app_full 提供 Streamlit 服務)
