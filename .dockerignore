.pytest_cache
.coverage
htmlcov
.tox
.nox
tests
*_test.py
test_*.py

# 桌面應用程式 (Streamlit 容器化部署不需要桌面版程式與其巨大的 vendor 依賴庫)
desktop_app
scripts/RUN_DESKTOP_APP.bat

# IDE 與編輯器
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Git 相關
.git
.gitignore
