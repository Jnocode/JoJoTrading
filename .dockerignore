.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE 和編輯器
.vscode/
.idea/
*.swp
*.swo
*~

# 系統文件
.DS_Store
Thumbs.db

# Git 相關
.git/
.gitignore
.gitattributes

# 日誌文件
logs/
*.log

# 暫存文件
temp/
tmp/
