*.example
*.template
*.sample

# 緩存文件（保留目錄結構但排除內容）
cache/*
!cache/.gitkeep

# 數據文件（生產環境通過卷掛載）
data/raw/
data/processed/
data/cache/

# Docker 相關
Dockerfile
docker-compose*.yml
.dockerignore

