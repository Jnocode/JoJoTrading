classDiagram
    direction LR

    %% --- StateMachineModule (jojo_state_machine.py) ---
    class JoJoState {
        <<enumeration>>
        CONFIG_LOAD
        UI_INIT
        INDUSTRY_PROCESS
        DATA_FETCH
        VALUATION
        FILTERING
        RESULTS_DISPLAY
        ERROR 
        IDLE 
        # EXPORT and END are not currently implemented or used in the state machine
    }

    class State {
        <<Abstract>>
        +context dict
        +machine JoJoStateMachine
        +execute() void
    }

    class ConfigLoadState
    class UiInitState
    class IndustryProcessState
    class DataFetchState
    class ValuationState
    class FilteringState
    class ResultsDisplayState
    %% class ExportState %% Not yet implemented
    class ErrorState
    class IdleState   
    %% Added IDLE state
    %% class EndState %% Not yet implemented

    ConfigLoadState --|> State
    UiInitState --|> State
    IndustryProcessState --|> State
    DataFetchState --|> State
    ValuationState --|> State
    FilteringState --|> State
    ResultsDisplayState --|> State
    %% ExportState --|> State
    ErrorState --|> State
    IdleState --|> State 
    %% Added IDLE state inheritance

    class JoJoStateMachine {
        +current_state JoJoState
        +context dict
        +__init__() void
        +transition_to(next_state JoJoState) void
        +execute_state() void
    }
    JoJoStateMachine o-- JoJoState : "current_state"
    JoJoStateMachine *-- State : "uses state objects" # Changed from manages to uses for clarity

    %% --- AppModule (app.py) ---
    class StreamlitApp {
        <<Streamlit Script>>
        -machine JoJoStateMachine
        +render_ui()
        +handle_user_interaction()
    }
    StreamlitApp ..> JoJoStateMachine : creates & drives

    %% --- DataHandlerModule (data_handler.py) ---
    class DataHandler_Functions {
