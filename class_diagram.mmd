        +get_all_companies_basic_data(context) list
        +filter_industry_stocks(selected_industry_name, name_to_code_map, all_companies_data) list
        # +get_financial_reports_for_stock(stock_detail, context) tuple # This was for old TWSE API
        # +fetch_stock_financials_from_downloaded(stock_code, api_suffix, downloaded_reports) dict # This was for old TWSE API
        +fetch_finmind_financial_statement_data(stock_id str, start_date str, statement_type str) DataFrame
        +extract_finmind_items(df DataFrame, target_items_map dict, report_date_str str, max_lookback_periods int) dict
        +fetch_finmind_stock_price(stock_id str, target_date_str str) float
        +calculate_dcf_valuation(stock_code str, financials dict, risk_preference float, context dict) dict
    }
    DataFetchState ..> DataHandler_Functions : uses
    ValuationState ..> DataHandler_Functions : uses
    ConfigLoadState ..> DataHandler_Functions : uses (for get_all_companies_basic_data)

